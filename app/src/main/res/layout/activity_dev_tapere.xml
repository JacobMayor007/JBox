<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/taps"
    android:orientation="vertical"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D8000000"
        android:orientation="vertical"
        >
        <ImageView
            android:id="@+id/close"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/close"
            />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Jacob Mary Tapere"
                android:textColor="@color/white"
                android:textSize="32dp"
                android:textStyle="bold"

                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="jacobmary.tapere007@gmail.com"
                android:textColor="@color/white"
                android:textSize="12dp"
                android:textStyle="bold"

                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Project Manager"
                android:textColor="@color/white"
                android:textSize="24dp"
                android:textStyle="bold"


                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Death before Dishonor"
                android:textColor="@color/white"
                android:textSize="16dp"

                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:text="More than 60+ Years of Experience in ReactJS, NodeJS, Kotlin, Java, C#, C++, Python. Willing to work Under Pressure."
                android:textColor="@color/white"
                android:textSize="16dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="The Team"
            android:textColor="@color/white"
            android:textSize="16dp"
            android:layout_marginTop="8dp"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            >

            <ImageView
                android:id="@+id/tapere"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:src="@drawable/taps"

                />
            <ImageView
                android:id="@+id/aiken"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:src="@drawable/me"
                />

            <ImageView
                android:id="@+id/johanna"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:src="@drawable/johanna" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>